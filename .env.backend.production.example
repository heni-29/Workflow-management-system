DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-backend.onrender.com

# Frontend origin(s) allowed to call backend
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com,https://your-backend.onrender.com

# Required for production services
DATABASE_URL=postgres://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379/0

# Optional hardening (default is 1 when DJANGO_DEBUG=0)
SECURE_SSL_REDIRECT=1
